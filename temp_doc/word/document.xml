<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:document xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:cdr="http://schemas.openxmlformats.org/drawingml/2006/chartDrawing" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:ve="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:vt="http://schemas.openxmlformats.org/officeDocument/2006/docPropsVTypes" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" xmlns:asvg="http://schemas.microsoft.com/office/drawing/2016/SVG/main"><w:body><w:p><w:pPr><w:spacing w:line="270" w:before="157.5" w:after="157.5" w:lineRule="auto"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="0" w:name="bizflow_product_overview_document"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="39"/></w:rPr><w:t xml:space="preserve">BizFlow — Product Overview Document</w:t></w:r><w:bookmarkEnd w:id="0"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Version 1.0 | April 2026</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="210" w:after="0" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:pict><v:rect alt="" style="width:475.5pt;height:.05pt;mso-width-percent:0;mso-height-percent:0;mso-width-percent:0;mso-height-percent:0" o:hralign="center" o:hrstd="t" o:hr="f"><v:stroke filltype="solid" color="#000000" opacity="0" weight="1.0pt"/></v:rect></w:pict></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="1" w:name="executive_summary"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Executive Summary</w:t></w:r><w:bookmarkEnd w:id="1"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow is a complete Business Operating System designed for retail stores, restaurants, and service businesses. It replaces the fragmented mix of billing software, spreadsheets, and manual tracking that most small and mid-sized businesses rely on today — with a single, unified platform that covers every operational area from the point of sale to profit reporting.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">The platform is built for multi-business deployment, supports full white-label branding, and includes a three-phase AI roadmap that grows from daily business insights to predictive and autonomous decision support.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="210" w:after="0" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:pict><v:rect alt="" style="width:475.5pt;height:.05pt;mso-width-percent:0;mso-height-percent:0;mso-width-percent:0;mso-height-percent:0" o:hralign="center" o:hrstd="t" o:hr="f"><v:stroke filltype="solid" color="#000000" opacity="0" weight="1.0pt"/></v:rect></w:pict></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="2" w:name="the_problem_bizflow_solves"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">The Problem BizFlow Solves</w:t></w:r><w:bookmarkEnd w:id="2"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Most small and mid-sized businesses in India and emerging markets run operations across disconnected tools — a billing app here, a stock register there, manual staff records, and a separate accounting tool. This creates a fragmented picture of the business, leads to stock losses, billing errors, and delayed financial reporting, and makes scaling to multiple locations extremely difficult.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow brings all of this into one place — so business owners have complete operational control and real-time visibility from a single screen.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="210" w:after="0" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:pict><v:rect alt="" style="width:475.5pt;height:.05pt;mso-width-percent:0;mso-height-percent:0;mso-width-percent:0;mso-height-percent:0" o:hralign="center" o:hrstd="t" o:hr="f"><v:stroke filltype="solid" color="#000000" opacity="0" weight="1.0pt"/></v:rect></w:pict></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="3" w:name="who_bizflow_is_for"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Who BizFlow Is For</w:t></w:r><w:bookmarkEnd w:id="3"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="4" w:name="retail_stores"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Retail Stores</w:t></w:r><w:bookmarkEnd w:id="4"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Medical shops, grocery stores, and general retail outlets gain precise inventory control, fast billing with barcode support, and real-time supplier tracking. The platform is especially well-suited for businesses that deal with expiry-sensitive products, high transaction volumes, or multiple product variants.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="5" w:name="restaurants"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Restaurants</w:t></w:r><w:bookmarkEnd w:id="5"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow supports the full dining workflow — from order entry to kitchen dispatch, ingredient stock tracking, and end-of-shift reporting. Restaurants benefit from real-time stock depletion tied directly to sales, and accurate daily cost tracking.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="6" w:name="service_businesses"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Service Businesses</w:t></w:r><w:bookmarkEnd w:id="6"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Salons, clinics, repair shops, and professional service providers can manage billing, staff attendance, advance payments, and expense tracking without juggling multiple applications.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="210" w:after="0" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:pict><v:rect alt="" style="width:475.5pt;height:.05pt;mso-width-percent:0;mso-height-percent:0;mso-width-percent:0;mso-height-percent:0" o:hralign="center" o:hrstd="t" o:hr="f"><v:stroke filltype="solid" color="#000000" opacity="0" weight="1.0pt"/></v:rect></w:pict></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="7" w:name="core_capabilities"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Core Capabilities</w:t></w:r><w:bookmarkEnd w:id="7"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="8" w:name="sales_billing"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Sales &amp; Billing</w:t></w:r><w:bookmarkEnd w:id="8"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow generates invoices in seconds with barcode scanning support. It accepts all major payment modes — cash, UPI, card, and split payments — and handles discounts and tax calculations automatically. Every invoice is linked to inventory so stock levels update in real time at the point of sale.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="9" w:name="inventory_management"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Inventory Management</w:t></w:r><w:bookmarkEnd w:id="9"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Stock levels are always accurate because BizFlow enforces a strict movement-based inventory model. Every change — a purchase, a sale, a return, a damaged unit, or an expired item — is recorded as a discrete stock movement. Inventory is never edited directly. This produces four reliable stock categories at all times: available (sellable), damaged, expired, and reserved.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="10" w:name="returns_refunds"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Returns &amp; Refunds</w:t></w:r><w:bookmarkEnd w:id="10"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Returns are processed against the original invoice. The condition of the returned item is recorded — good condition items return to available stock, damaged items are logged as damaged, and expired items are counted separately. This ensures inventory accuracy is never compromised by returns.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="11" w:name="purchase_supplier_management"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Purchase &amp; Supplier Management</w:t></w:r><w:bookmarkEnd w:id="11"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow tracks every purchase order and supplier relationship. Cost prices are recorded with each purchase, enabling accurate profit calculation. Inventory is updated automatically when a purchase is received — no manual stock entry required.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="12" w:name="expense_tracking"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Expense Tracking</w:t></w:r><w:bookmarkEnd w:id="12"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Business expenses are categorised and tracked daily. These figures feed directly into profit and loss reports, giving owners a complete and accurate view of net profitability — not just top-line revenue.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="13" w:name="staff_management"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Staff Management</w:t></w:r><w:bookmarkEnd w:id="13"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">Staff records, daily attendance, salary processing, and advance tracking are managed within the platform. Business owners can monitor attendance across locations and review salary and advance history at any time.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="14" w:name="reports_analytics"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">Reports &amp; Analytics</w:t></w:r><w:bookmarkEnd w:id="14"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow generates daily sales reports, profit and loss summaries, inventory reports, and expense breakdowns automatically. A dashboard view surfaces the most important metrics for a business at a glance — no manual reporting required.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="210" w:after="0" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:pict><v:rect alt="" style="width:475.5pt;height:.05pt;mso-width-percent:0;mso-height-percent:0;mso-width-percent:0;mso-height-percent:0" o:hralign="center" o:hrstd="t" o:hr="f"><v:stroke filltype="solid" color="#000000" opacity="0" weight="1.0pt"/></v:rect></w:pict></w:r></w:p><w:p><w:pPr><w:spacing w:line="360" w:before="315" w:after="105" w:lineRule="auto"/><w:ind w:left="-30"/><w:jc w:val="left"/></w:pPr><w:bookmarkStart w:id="15" w:name="ai_powered_intelligence"/><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:b/><w:color w:val="000000"/><w:sz w:val="24"/></w:rPr><w:t xml:space="preserve">AI-Powered Intelligence</w:t></w:r><w:bookmarkEnd w:id="15"/></w:p><w:p><w:pPr><w:spacing w:line="360" w:after="210" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="georgia" w:cs="georgia" w:ascii="georgia" w:hAnsi="georgia"/><w:color w:val="000000"/></w:rPr><w:t xml:space="preserve">BizFlow's AI layer is a three-phase capability roadmap designed to grow with the business.</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblStyle w:val="TableGrid"/><w:jc w:val="center"/><w:tblCellSpacing w:w="0" w:type="dxa"/><w:tblBorders><w:top w:val="single" w:sz="2" w:space="0" w:color="000000"/><w:left w:val="single" w:sz="2" w:space="0" w